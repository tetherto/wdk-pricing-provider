{
  "name": "@tetherto/wdk-pricing-provider",
  "version": "1.0.0-beta.2",
  "description": "Asset pricing provider for the WDK.",
  "keywords": [
    "tetherto",
    "wdk",
    "wallet",
    "bitcoin",
    "ethereum",
    "pricing",
    "provider",
    "bitfinex",
    "blockchain"
  ],
  "license": "APACHE-2.0",
  "repository": {
    "type": "git",
    "url": "git://github.com/tetherto/lib-wallet-pricing-provider.git"
  },
  "main": "index.js",
  "scripts": {
    "lint": "standard",
    "lint:fix": "standard --fix",
    "test": "cross-env NODE_OPTIONS=--experimental-vm-modules jest",
    "test:coverage": "cross-env NODE_OPTIONS=--experimental-vm-modules jest --coverage",
    "test:integration": "cross-env NODE_OPTIONS=--experimental-vm-modules jest tests/integration",
    "test:integration:coverage": "cross-env NODE_OPTIONS=--experimental-vm-modules jest tests/integration --coverage",
    "test:bare": "bare tests/bare-runtime.test.mjs",
    "build:types": "tsc"
  },
  "type": "module",
  "author": "Tether",
  "types": "./index.d.ts",
  "exports": {
    ".": {
      "types": "./types/index.d.ts",
      "bare": "./bare.js",
      "default": "./index.js"
    },
    "./package": {
      "default": "./package.json"
    }
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "standard": {
    "ignore": [
      "bare.js",
      "tests/**/*.js"
    ]
  },
  "dependencies": {
    "bare-node-runtime": "^1.2.0"
  },
  "devDependencies": {
    "cross-env": "^10.1.0",
    "brittle": "^3.0.0",
    "jest": "^30.2.0",
    "standard": "^17.1.2",
    "typescript": "^5.7.2"
  },
  "jest": {
    "testPathIgnorePatterns": [
      "/tests/bare-runtime.test.mjs$"
    ]
  }
}
